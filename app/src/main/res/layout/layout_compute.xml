<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/displayGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message Natif"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/displayFactorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Résultat Factoriel"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/displayInverted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Texte Inversé"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/displayTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Tableau"
            android:textSize="18sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>